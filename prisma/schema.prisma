generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum Filiere {
  MP
  PC
  TSI
  BIO
  TECHNO
}

enum Matiere {
  MATHEMATIQUES
  PHYSIQUE
  SCIENCES_INGENIEUR
  AUTRE
}

enum Difficulte {
  UN_ETOILE
  DEUX_ETOILES
  TROIS_ETOILES
}

enum PostStatus {
  PUBLISHED
  REPORTED
  REMOVED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  nom          String
  prenom       String
  role         Role       @default(STUDENT)
  status       UserStatus @default(ACTIVE)
  emailVerified Boolean   @default(false)
  ecole        String?
  filiere      Filiere?
  xpTotal      Int        @default(0)
  streak       Int        @default(0)

  attempts        ExerciseAttempt[]
  contestSessions ContestSession[]
  posts           ForumPost[]
  replies         ForumReply[]
  likes           ForumLike[]
  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Exercise {
  id                String     @id @default(uuid())
  titre             String
  matiere           Matiere
  difficulte        Difficulte
  enonce            String     @db.Text
  hint1             String?    @db.Text
  hint2             String?    @db.Text
  hint3             String?    @db.Text
  hint4             String?    @db.Text
  solutionDetaillee String     @db.Text
  xpBase            Int        @default(10)

  choix    ExerciseChoice[]
  attempts ExerciseAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exercises")
}

model ExerciseChoice {
  id         String   @id @default(uuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  label      String
  isCorrect  Boolean  @default(false)

  @@map("exercise_choices")
}

model ExerciseAttempt {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId       String
  exercise         Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  selectedChoiceId String?
  isCorrect        Boolean
  hintsUsed        Int      @default(0)
  xpEarned         Int      @default(0)
  createdAt        DateTime @default(now())

  @@map("exercise_attempts")
}

model Contest {
  id      String   @id @default(uuid())
  titre   String
  annee   Int
  filiere Filiere
  matiere Matiere?

  questions ContestQuestion[]
  sessions  ContestSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contests")
}

model ContestQuestion {
  id                String  @id @default(uuid())
  contestId         String
  contest           Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  ordre             Int
  enonce            String  @db.Text
  hint1             String? @db.Text
  hint2             String? @db.Text
  hint3             String? @db.Text
  hint4             String? @db.Text
  solutionDetaillee String  @db.Text
  xpBase            Int     @default(10)

  choix   ContestQuestionChoice[]
  answers ContestSessionAnswer[]

  @@unique([contestId, ordre])
  @@map("contest_questions")
}

model ContestQuestionChoice {
  id         String          @id @default(uuid())
  questionId String
  question   ContestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String
  isCorrect  Boolean         @default(false)

  @@map("contest_question_choices")
}

model ContestSession {
  id                 String    @id @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contestId          String
  contest            Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  questionsCompleted Int       @default(0)
  xpTotal            Int       @default(0)
  isCompleted        Boolean   @default(false)
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  answers ContestSessionAnswer[]

  @@map("contest_sessions")
}

model ContestSessionAnswer {
  id               String          @id @default(uuid())
  sessionId        String
  session          ContestSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId       String
  question         ContestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedChoiceId String?
  isCorrect        Boolean
  hintsUsed        Int             @default(0)
  xpEarned         Int             @default(0)
  answeredAt       DateTime        @default(now())

  @@unique([sessionId, questionId])
  @@map("contest_session_answers")
}

// ─── FORUM ────────────────────────────────────────────────────────────────────

model ForumPost {
  id       String     @id @default(uuid())
  authorId String
  author   User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  titre    String
  contenu  String     @db.Text
  matiere  Matiere
  status   PostStatus @default(PUBLISHED)

  replies ForumReply[]
  likes   ForumLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forum_posts")
}

model ForumReply {
  id       String    @id @default(uuid())
  postId   String
  post     ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  contenu  String    @db.Text

  likes ForumLike[]

  createdAt DateTime @default(now())

  @@map("forum_replies")
}

model ForumLike {
  id      String     @id @default(uuid())
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId  String?
  post    ForumPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  replyId String?
  reply   ForumReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@map("forum_likes")
}

// ─── PLATFORM SETTINGS ────────────────────────────────────────────────────────

model PlatformSettings {
  id Int @id @default(1)

  platformName   String  @default("NEXA")
  supportEmail   String? @default("support@nexa.tn")
  websiteUrl     String? @default("https://nexa.tn")

  xpPerDirectAnswer   Int @default(10)
  xpPerForumPost      Int @default(3)
  xpPerForumReply     Int @default(1)
  hintPenaltyPercent1 Int @default(10)
  hintPenaltyPercent2 Int @default(20)
  hintPenaltyPercent3 Int @default(30)
  hintPenaltyPercent4 Int @default(40)

  maintenanceMode Boolean @default(false)

  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}
